{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "jarvis",
    "main": "frontend/public/_worker.js",
    "compatibility_date": "2024-03-20",
    "observability": {
        "enabled": true
    },
    "assets": {
        "directory": "frontend/dist"
    },
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "vars": {
        "BACKEND_URL": "https://your-backend.example.com"
    }
}